rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Seguridad por Defecto: Denegar Todo
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers Globales ---
    function isSignedIn() { return request.auth != null; }
    function isVerified() { return isSignedIn() && request.auth.token.email_verified == true; }
    function isTeacher() { 
      return isVerified() && request.auth.token.email == 'morenoquinterojaidersebastian@gmail.com'; 
    }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }

    // --- Perfiles de Usuario ---
    match /users/{userId} {
      allow get: if isSignedIn();
      allow create: if isOwner(userId) && 
                      incoming().role == (request.auth.token.email == 'morenoquinterojaidersebastian@gmail.com' ? 'teacher' : 'student');
      allow update: if isTeacher() || (isOwner(userId) && incoming().diff(existing()).affectedKeys().hasOnly(['displayName']));
    }

    // --- Lecciones y Contenido (Solo docente modifica) ---
    match /lessons/{lessonId} {
      allow read: if isSignedIn();
      allow create, update, delete: if isTeacher();

      match /resources/{resId} {
        allow read: if isSignedIn();
        allow write: if isTeacher();
      }

      match /activities/{actId} {
        allow read: if isSignedIn();
        allow write: if isTeacher();
      }
    }

    // --- Entregas (Alumnos crean, Docente califica) ---
    match /submissions/{subId} {
      allow read: if isSignedIn() && (isTeacher() || existing().studentId == request.auth.uid);
      allow list: if isSignedIn(); // Filtrado por where('studentId', '==', uid) en el cliente
      
      allow create: if isVerified() && 
                      incoming().studentId == request.auth.uid &&
                      incoming().status == 'submitted';
      
      allow update: if isTeacher() && incoming().diff(existing()).affectedKeys().hasOnly(['grade', 'feedback', 'status']);
      allow delete: if isTeacher() || (isOwner(existing().studentId) && existing().status == 'submitted');
    }
  }
}
